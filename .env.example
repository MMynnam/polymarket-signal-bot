# =============================================================================
# Polymarket Insider Signal Bot — Environment Variables
# Copy this file to .env and fill in your values.
# Never commit .env to version control.
# =============================================================================


# =============================================================================
# REQUIRED — Bot will refuse to start without these
# =============================================================================

# Telegram bot token — get from @BotFather on Telegram
# Example: 1234567890:ABCdefGHIjklMNOpqrsTUVwxyz
TELEGRAM_BOT_TOKEN=

# Telegram chat ID to send alerts to.
# To find your chat ID:
#   1. Start a conversation with your bot or add it to a group.
#   2. Send a message.
#   3. Visit: https://api.telegram.org/bot<TOKEN>/getUpdates
#   4. Look for "chat": {"id": <number>}
# For groups this will be a negative number (e.g. -1001234567890)
TELEGRAM_CHAT_ID=


# =============================================================================
# STRONGLY RECOMMENDED — Enables wallet age scoring (Etherscan V2)
# =============================================================================

# Free Etherscan V2 API key — covers Polygon (chainid=137) and all EVM chains.
# Sign up at: https://etherscan.io/register
# Then generate an API key at: https://etherscan.io/myapikey
# Free tier: 100,000 calls/day, 3 calls/second — sufficient for this bot.
ETHERSCAN_API_KEY=


# =============================================================================
# OPTIONAL — Enables proxy wallet cluster detection (Alchemy)
# =============================================================================

# Alchemy RPC URL for Polygon — full URL including your API key.
# Sign up at: https://www.alchemy.com (free tier: 30M compute units/month)
# Example: https://polygon-mainnet.g.alchemy.com/v2/YOUR_KEY_HERE
# WARNING: Only used for alchemy_getAssetTransfers on new wallets.
# Do NOT use Alchemy for routine polling — it will exhaust the free tier.
ALCHEMY_RPC_URL=


# =============================================================================
# TUNABLE — Override defaults from config.py
# =============================================================================

# Minimum USD trade size to process (default: 500)
# Raising this reduces noise; lowering it increases volume.
TRADE_MIN_SIZE_USD=500

# Two-tier alert thresholds.
# Scores >= ALERT_INSTANT_THRESHOLD fire an immediate Telegram message.
# Scores in [ALERT_DIGEST_THRESHOLD, ALERT_INSTANT_THRESHOLD) are batched
# into a periodic digest sent every DIGEST_INTERVAL_SECONDS.
ALERT_INSTANT_THRESHOLD=80
ALERT_DIGEST_THRESHOLD=60
DIGEST_INTERVAL_SECONDS=7200

# SQLite database file path (default: polymarket_bot.db)
# On Railway, use /data/polymarket_bot.db if you mount a persistent volume.
SQLITE_DB_PATH=polymarket_bot.db

# Wallet profile cache TTL in seconds (default: 21600 = 6 hours)
WALLET_CACHE_TTL_SECONDS=21600

# Market discovery polling interval in seconds (default: 300 = 5 minutes)
MARKET_DISCOVERY_INTERVAL_SECONDS=300

# REST fallback polling interval in seconds (default: 30)
TRADE_POLL_INTERVAL_SECONDS=30

# Max trades to pull per wallet for history analysis (default: 10000)
WALLET_TRADE_HISTORY_LIMIT=10000

# Telegram rate limit: minimum seconds between messages (default: 1.5)
TELEGRAM_RATE_LIMIT_SECONDS=1.5

# HTTP request timeout in seconds (default: 15)
HTTP_TIMEOUT_SECONDS=15

# HTTP retry attempts for API calls (default: 3)
HTTP_MAX_RETRIES=3

# --- Timing curve parameters ---
# Bets within this many hours of close score near max timing points (default: 2.0)
TIMING_MAX_SCORE_HOURS=2.0
# Bets beyond this many hours score near zero timing points (default: 168 = 7 days)
TIMING_ZERO_SCORE_HOURS=168

# --- Dry run mode ---
# Set to true to run the full pipeline without sending Telegram messages.
# Also activatable with: python main.py --dry-run
DRY_RUN=false

# --- Logging ---
# DEBUG for verbose output, INFO for normal, WARNING for quiet (default: INFO)
LOG_LEVEL=INFO

# --- Max Gamma markets per discovery poll (default: 200) ---
GAMMA_MARKETS_LIMIT=200
